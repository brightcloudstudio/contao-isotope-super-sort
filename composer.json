{
    "name": "bright-cloud-studio/contao-isotope-super-sort",
    "description": "Customized manual sorting for Isotope eCommerce product lists. Contao 5 / Isotope 3 rewrite of asconsulting/isotope_super_sort.",
    "keywords": ["contao", "isotope", "ecommerce", "sorting"],
    "type": "contao-bundle",
    "homepage": "http://brightcloudstudio.com/",
    "license": "LGPL-3.0+",
    "authors": [
        {
            "name": "Bright Cloud Studio",
            "homepage": "https://brightcloudstudio.com",
            "email": "mark@brightcloudstudio.com",
            "role": "Developer"
        },
        {
            "name": "Andrew Stevens",
            "homepage": "https://andrewstevens.consulting",
            "role": "Original author"
        }
    ],
    "support": {
        "issues": "https://github.com/brightcloudstudio/contao-isotope-super-sort/issues",
        "source": "https://github.com/brightcloudstudio/contao-isotope-super-sort"
    },
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.7",
        "isotope/isotope-core": "^3.0",
        "doctrine/dbal": "^3.6 || ^4.0",
        "ramsey/collection": "^1.3 || ^2.0",
        "symfony/http-foundation": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Bcs\\IsotopeSuperSortBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Bcs\\IsotopeSuperSortBundle\\ContaoManager\\Plugin"
    }
}
